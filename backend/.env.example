# Backend env (do not commit real keys)
PORT=3001

# Comma-free single origin for dev CORS (optional)
# 예: http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# 서울시 열린데이터 OpenAPI 인증키 (필수) — 문화행사(/api/events)와 식품인증업소 관리(FsaCrtfcUpsoMgtNew,
# /api/seoul/nearby-food-cert)가 동일 키를 사용합니다. 별도의 식품전용 키 변수는 없습니다.
SEOUL_API_KEY=

# 식품인증업소 관리 API 서비스명만 필요 시 변경 — 미설정 시 기본 FsaCrtfcUpsoMgtNew
# 공식 샘플: http://openapi.seoul.go.kr:8088/(인증키)/xml/FsaCrtfcUpsoMgtNew/1/5/
# 백엔드는 JSON으로 동일 서비스 호출: .../json/FsaCrtfcUpsoMgtNew/start/end/
# SEOUL_FOOD_CERT_SERVICE=FsaCrtfcUpsoMgtNew

# LLM provider
LLM_PROVIDER=gemini

# LLM(Gemini) 키 (선택: AI 코스 생성 기능 사용 시 필수)
GEMINI_API_KEY=

# LLM 모델 (선택)
GEMINI_MODEL=gemini-2.5-flash

# 기본 모델이 503/429 등으로 불안정할 때 한 번 더 시도할 fallback 모델 (선택)
GEMINI_FALLBACK_MODEL=gemini-2.0-flash

