# Backend env (do not commit real keys)
PORT=3001

# Comma-free single origin for dev CORS (optional)
# 예: http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# 서울시 OpenAPI 키 (필수)
SEOUL_API_KEY=

# LLM provider
LLM_PROVIDER=gemini

# LLM(Gemini) 키 (선택: AI 코스 생성 기능 사용 시 필수)
GEMINI_API_KEY=

# LLM 모델 (선택)
GEMINI_MODEL=gemini-2.5-flash

# 기본 모델이 503/429 등으로 불안정할 때 한 번 더 시도할 fallback 모델 (선택)
GEMINI_FALLBACK_MODEL=gemini-2.0-flash

