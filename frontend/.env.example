# (기존) 프론트에서 서울시 OpenAPI를 직접 호출하던 키 — 이제는 백엔드 프록시에서만 사용합니다.
# 이 값은 더 이상 필요하지 않습니다(호환을 위해 남겨둠).
VITE_SEOUL_API_KEY=

# true 이면 브라우저에서 실제 API 를 호출하지 않고 mock 데이터만 사용 (CORS·키 없이 개발)
VITE_USE_MOCK_DATA=false

# 백엔드 프록시 베이스 URL (선택)
# - 설정하면 `${VITE_BACKEND_BASE_URL}/api/events`로 호출
# - 미설정이면 `/api/events` 상대경로 호출(배포 시 같은 오리진 권장)
VITE_BACKEND_BASE_URL=http://localhost:3001

# LLM 코스 생성 사용 여부 (선택)
# - true: 후보 5~8개를 백엔드 POST /api/ai/course로 보내 LLM 결과를 시도
# - 실패 시 자동으로 규칙 기반 목업 코스로 폴백
VITE_USE_LLM=false
